{
  "extends": [
    "@eslint/js/recommended"
  ],
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", { "varsIgnorePattern": "^[A-Z_]" }]
  },
  "overrides": [
    {
      "files": ["**/*.css"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
